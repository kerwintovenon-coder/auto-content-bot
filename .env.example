# Environment Configuration Template
# Copy this file to .env and fill in your credentials

# WordPress Configuration
WP_SITE_URL=https://milgrp.com
WP_USER=user
WP_APP_PASS=your_wordpress_app_password
WP_EMAIL=info@milgrp.com

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# GitHub Configuration
GITHUB_TOKEN=your_github_token
GITHUB_REPO=kerwintovenon-coder/auto-content-bot

# Target Configuration
TARGET_EMAIL=info@milgrp.com
DAILY_POST_COUNT=30
EXISTING_PRODUCT_COUNT=15
NEW_PRODUCT_COUNT=15

# Logging
LOG_LEVEL=INFO
